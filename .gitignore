# --- Project Specific ---
# 대용량 원시 데이터 및 가공 데이터 제외
data/*
!data/.gitkeep
!data/collection_summary.json
!data/video_ids.txt
# 학습된 모델 파일 (pth, pkl, joblib, h5 등) 제외
models/*
!models/.gitkeep
# 분석 결과물 (시각화 이미지, 리포트 등)
results/*
!results/.gitkeep

# --- Python & uv ---
# uv가 생성하는 가상 환경 폴더
.venv/
# python 빌드 및 캐시
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# --- Jupyter Notebook ---
# 노트북 체크포인트 및 임시 파일
.ipynb_checkpoints
*/.ipynb_checkpoints/*
# 노트북 실행 중 생성되는 런타임 정보
.local

# --- OS & IDE ---
# macOS
.DS_Store
# Windows
Thumbs.db
# VS Code / JetBrains
.vscode/
.idea/

# --- Environment Variables ---
# 민감한 API 키나 설정값이 포함된 파일
.env